# Environment Variables Template
PORT=8000
HOST=0.0.0.0

ULTRAVOX_API_KEY="your_ultravox_api_key_here"
SARVAM_API_KEY="your_sarvam_api_key_here"

# Vobiz SIP Trunking Credentials
VOBIZ_AUTH_ID="your_vobiz_auth_id"
VOBIZ_AUTH_TOKEN="your_vobiz_auth_token"
VOBIZ_FROM_NUMBER="+911171366938"

# The backend URL must be publicly accessible (e.g. ngrok or deployed IP) for the Ultravox webhook
BACKEND_URL="http://localhost:8000"

# Optional: Set this to true to use Sarvam TTS via the proxy webhook
USE_SARVAM_TTS=true
